<div class="fixed top-5 right-5 z-[100] space-y-3 w-full max-w-sm">
  <% flash.each do |type, msg| %>
    <div data-controller="flash"
         class="flex items-center p-4 rounded-2xl border backdrop-blur-md shadow-2xl transition-all duration-500 transform translate-x-0"
         style="<%= type == 'notice' ? 'background: rgba(20, 83, 45, 0.4); border-color: #166534; color: #4ade80;' : 'background: rgba(153, 27, 27, 0.4); border-color: #991b1b; color: #f87171;' %>">

      <%# Иконка %>
      <div class="mr-3">
        <% if type == 'notice' %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        <% else %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <% end %>
      </div>

      <div class="flex-1 font-medium"><%= msg %></div>

      <%# Кнопка закрытия %>
      <button data-action="click->flash#close" class="ml-4 hover:opacity-70 transition-opacity">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  <% end %>
</div>
