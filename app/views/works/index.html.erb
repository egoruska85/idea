<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
  </head>
  <body class="bg-gray-950 text-white font-sans">
    <%= render 'include/navbar' %>

    <section id="works" class="text-center py-24 px-6">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">Мои работы</h1>
      <div class="grid md:grid-cols-3 gap-6">
        <% if @works.present? %>

          <% @works.each do |work| %>
            <div class="bg-gray-800 p-4 rounded-xl transition hover:scale-105 hover:shadow-lg">
              <h4 class="text-yellow-400 text-lg"><%= work.title %></h4>
              <p class="text-gray-400 text-sm"><%= work.service.title %></p>

              <p class="mt-2 text-sm">
                <%= truncate(work.body, length: 100) %>
              </p>

              <% if work.images.attached? %>
                <img src="<%= url_for(work.images.first) %>" class="w-24 mx-auto my-2 rounded" />
              <% end %>

              <%= link_to 'Подробнее', work_path(work),
                class:'bg-blue-500 hover:bg-blue-700 text-white text-sm px-4 py-2 rounded-full inline-block mt-2' %>
            </div>
          <% end %>

          <% (6 - @works.count).times do %>
            <div class="bg-gray-800 h-60 rounded-xl flex items-center justify-center">
              <span class="text-gray-500">Скоро здесь будет работа</span>
            </div>
          <% end %>

        <% else %>

          <% 6.times do %>
            <div class="bg-gray-800 h-60 rounded-xl flex items-center justify-center">
              <span class="text-gray-500">Работы пока не опубликованы</span>
            </div>
          <% end %>

        <% end %>
      </div>
      <% if @works.empty? %>
        <center><h1 style="font-size: 100px; color: rgba(200, 200, 200, 0.1);">Работы пока не опубликованы</h1></center>
        <br><br><br><br><br><br><br><br><br><br><br><br><br><br>
      <% end %>
    </section>
    <script src="/assets/js/script.js"></script>
  </body>
</html>
