<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
  </head>
  <body class="bg-gray-950 text-white font-sans">
    <%= render 'include/navbar' %>

    <section class="text-center py-24 px-6 max-w-7xl mx-auto" data-controller="lightbox">

      <%# --- Оверлей (скрыт по умолчанию) --- %>
      <div data-lightbox-target="overlay"
           data-action="click->lightbox#close"
           class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4 cursor-zoom-out">
        <img data-lightbox-target="fullImage" src="" class="max-w-full max-h-full rounded-lg shadow-2xl">
      </div>

      <%# --- Остальной контент --- %>
      <h2 class="text-4xl md:text-6xl font-bold mb-6"><%= @work.title %></h2>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-12">
        <% @work.images.each do |image| %>
          <div class="aspect-square overflow-hidden rounded-xl bg-gray-900">
            <%= image_tag image,
                class: "w-full h-full object-cover cursor-zoom-in hover:opacity-80 transition",
                data: { action: "click->lightbox#open" } %>
          </div>
        <% end %>
      </div>
    </section>


    <script src="/assets/js/script.js"></script>
  </body>

</html>
