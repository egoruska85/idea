<%= form_for @contact, html: { class: "max-w-3xl mx-auto bg-gray-900/50 p-6 md:p-10 rounded-3xl border border-gray-800 backdrop-blur-sm" } do |f| %>
  <div class="space-y-6">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%# Имя %>
      <div class="space-y-2">
        <%= f.label :name, t('contact.name'), class: "block text-sm font-medium text-gray-400 ml-1" %>
        <%= f.text_field :name,
            class: "w-full bg-gray-800 border border-gray-700 text-white rounded-2xl px-4 py-3 focus:border-pink-500 focus:ring-2 focus:ring-pink-500/20 outline-none transition-all placeholder:text-gray-600",
            placeholder: t('contact.name') %>
      </div>

      <%# Email %>
      <div class="space-y-2">
        <%= f.label :email, t('contact.mail'), class: "block text-sm font-medium text-gray-400 ml-1" %>
        <%= f.email_field :email,
            class: "w-full bg-gray-800 border border-gray-700 text-white rounded-2xl px-4 py-3 focus:border-pink-500 focus:ring-2 focus:ring-pink-500/20 outline-none transition-all placeholder:text-gray-600",
            placeholder: "example@mail.com" %>
      </div>
    </div>

    <%# Телефон %>
    <div class="space-y-2">
      <%= f.label :phone, t('contact.sales_phone'), class: "block text-sm font-medium text-gray-400 ml-1" %>
      <%= f.text_field :phone,
          value: '+',
          class: "w-full md:w-1/2 bg-gray-800 border border-gray-700 text-white rounded-2xl px-4 py-3 focus:border-pink-500 focus:ring-2 focus:ring-pink-500/20 outline-none transition-all",
          placeholder: t('contact.sales_phone') %>
    </div>

    <%# Сообщение %>
    <div class="space-y-2">
      <%= f.label :message, t('contact.message'), class: "block text-sm font-medium text-gray-400 ml-1" %>
      <%= f.text_area :message,
          rows: 5,
          class: "w-full bg-gray-800 border border-gray-700 text-white rounded-2xl px-4 py-3 focus:border-pink-500 focus:ring-2 focus:ring-pink-500/20 outline-none transition-all placeholder:text-gray-600",
          placeholder: t('contact.message') %>
    </div>

    <%# Файлы (Кастомный стиль кнопки) %>
    <div class="space-y-2">
      <label class="block text-sm font-medium text-gray-400 ml-1">Прикрепить ТЗ или референсы</label>
      <div class="relative group">
        <%= f.file_field :file, multiple: true,
            class: "block w-full text-sm text-gray-400
                    file:mr-4 file:py-2 file:px-4
                    file:rounded-full file:border-0
                    file:text-sm file:font-semibold
                    file:bg-pink-600 file:text-white
                    hover:file:bg-pink-700 file:transition-colors
                    cursor-pointer" %>
      </div>
    </div>

    <%# Кнопка отправки %>
    <div class="pt-4">
      <%= f.submit 'Отправить сообщение',
          class: "w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-4 px-8 rounded-2xl transition-all duration-300 transform hover:scale-[1.02] active:scale-95 cursor-pointer shadow-lg shadow-pink-600/20" %>
    </div>

  </div>
<% end %>
